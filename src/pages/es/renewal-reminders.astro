---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ArrowRight } from 'lucide-astro';
import type { Lang } from '../../i18n/ui';
const currentLang: Lang = 'es';

const features = [
  {
    title: 'Proactive Outreach',
    desc: 'Contacta clientes antes de que el contrato venza.',
    stat: '85%',
    statLabel: 'Tasa de renovación',
    color: 'oklch(0.65 0.15 145)',
    icon: '🔔',
  },
  {
    title: 'Contract Lifecycle',
    desc: 'Visualiza todos tus contratos y su estado.',
    stat: '40%',
    statLabel: 'Early renewals',
    color: 'oklch(0.75 0.15 195)',
    icon: '📅',
  },
  {
    title: 'Revenue Retention',
    desc: 'Identifica señales de churn temprano.',
    stat: '3x',
    statLabel: 'ROI en retention',
    color: 'oklch(0.70 0.15 235)',
    icon: '💰',
  },
];
---

<BaseLayout title="Renovaciones proactivas y retention" lang={currentLang}>
  <!-- Hero with Image Area -->
  <section class="hero-visual">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <div class="announce-badge fade-in">
            <span>🔄</span>
            <span>Revenue retention con IA</span>
          </div>
          <h1 class="hero-title fade-in" style="transition-delay:100ms;">
            No pierdas clientes por falta de seguimiento
          </h1>
          <p class="hero-sub fade-in" style="transition-delay:200ms;">
            La IA identifica quién está en riesgo y cuándo intervenir. Renovaciones proactivas que mantienen tu revenue fluyendo.
          </p>
          <div class="hero-ctas fade-in" style="transition-delay:300ms;">
            <a href={`/${currentLang}/demo`} class="btn btn-primary">
              Hablar con ventas <ArrowRight size={16} />
            </a>
            <a href="#" class="btn btn-outline">
              Empezar prueba gratis
            </a>
          </div>
        </div>
        <div class="hero-visual-area fade-in" style="transition-delay:200ms;">
          <div class="renewal-dashboard-visual">
            <div class="dash-header">
              <span>📊 Renewal Dashboard</span>
            </div>
            <div class="renewal-timeline">
              <div class="timeline-item urgent">
                <div class="tl-avatar">MG</div>
                <div class="tl-info">
                  <span class="tl-name">Maria Garcia - TechCorp</span>
                  <span class="tl-days">30 días</span>
                </div>
                <div class="tl-badge urgent">⚠️ Renewal</div>
              </div>
              <div class="timeline-item attention">
                <div class="tl-avatar">CR</div>
                <div class="tl-info">
                  <span class="tl-name">Carlos Ruiz - RetailMax</span>
                  <span class="tl-days">60 días</span>
                </div>
                <div class="tl-badge attention">📅 Review</div>
              </div>
              <div class="timeline-item ok">
                <div class="tl-avatar">AM</div>
                <div class="tl-info">
                  <span class="tl-name">Ana Martinez - FinanceHub</span>
                  <span class="tl-days">90 días</span>
                </div>
                <div class="tl-badge ok">✅ OK</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="stats-bar">
    <div class="container">
      <div class="stats-grid fade-in">
        <div class="stat-item">
          <span class="stat-val">85%</span>
          <span class="stat-lbl">Tasa de renovación</span>
        </div>
        <div class="stat-item">
          <span class="stat-val">40%</span>
          <span class="stat-lbl">Early renewals</span>
        </div>
        <div class="stat-item">
          <span class="stat-val">3x</span>
          <span class="stat-lbl">ROI en retention</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Features with Visual -->
  <section class="features-section">
    <div class="container">
      <div class="features-grid">
        {features.map((f, i) => (
          <div class="feature-card fade-in" style={`transition-delay:${i * 100}ms;`}>
            <div class="feature-visual">
              <div class="feature-icon-center">{f.icon}</div>
            </div>
            <div class="feature-content">
              <span class="feature-stat" style={`color: ${f.color};`}>{f.stat}</span>
              <span class="feature-stat-lbl">{f.statLabel}</span>
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline Visual -->
  <section class="timeline-section">
    <div class="container">
      <div class="timeline-header fade-in">
        <h2>Timeline de renovación</h2>
      </div>
      <div class="timeline-flow">
        <div class="timeline-step fade-in">
          <div class="step-marker at-risk">90d</div>
          <h4>Identificación</h4>
          <p>IA detecta señales de riesgo</p>
        </div>
        <div class="timeline-connector"></div>
        <div class="timeline-step fade-in" style="transition-delay:100ms;">
          <div class="step-marker attention">60d</div>
          <h4>Outreach inicial</h4>
          <p>Primer contacto con valor</p>
        </div>
        <div class="timeline-connector"></div>
        <div class="timeline-step fade-in" style="transition-delay:200ms;">
          <div class="step-marker warning">30d</div>
          <h4>Review ejecutivo</h4>
          <p>Llamada de negocio</p>
        </div>
        <div class="timeline-connector"></div>
        <div class="timeline-step fade-in" style="transition-delay:300ms;">
          <div class="step-marker success">0d</div>
          <h4>Renovación</h4>
          <p>Contrato renovado</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-card fade-in">
        <h2>Cada renewal es una oportunidad de crecer 🔄</h2>
        <div class="cta-btns">
          <a href={`/${currentLang}/demo`} class="btn btn-primary">Hablar con ventas</a>
          <a href="#" class="btn btn-outline">Empezar prueba gratis</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.hero-visual { padding: 140px 0 60px; }
.hero-content { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.announce-badge { display: inline-flex; align-items: center; gap: 10px; padding: 8px 16px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 9999px; font-size: 13px; color: rgba(255,255,255,0.7); margin-bottom: 24px; }
.hero-title { font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 800; line-height: 1.1; margin-bottom: 20px; }
.hero-sub { font-size: 18px; color: rgba(255,255,255,0.5); line-height: 1.6; margin-bottom: 32px; }
.hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; }
.renewal-dashboard-visual { background: linear-gradient(145deg, #1a1a1a, #0a0a0a); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 20px; }
.dash-header { font-size: 12px; color: rgba(255,255,255,0.5); margin-bottom: 16px; }
.renewal-timeline { display: flex; flex-direction: column; gap: 10px; }
.timeline-item { display: flex; align-items: center; gap: 12px; padding: 12px; background: #161616; border-radius: 10px; }
.tl-avatar { width: 36px; height: 36px; border-radius: 50%; background: #333; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; }
.timeline-item.urgent .tl-avatar { background: rgba(239, 68, 68, 0.2); color: #EF4444; }
.timeline-item.attention .tl-avatar { background: rgba(245, 158, 11, 0.2); color: #F59E0B; }
.timeline-item.ok .tl-avatar { background: rgba(34, 197, 94, 0.2); color: #22C55E; }
.tl-info { flex: 1; }
.tl-name { display: block; font-size: 13px; font-weight: 600; }
.tl-days { font-size: 11px; color: rgba(255,255,255,0.4); }
.tl-badge { font-size: 10px; font-weight: 700; padding: 4px 10px; border-radius: 8px; }
.tl-badge.urgent { background: rgba(239, 68, 68, 0.15); color: #EF4444; }
.tl-badge.attention { background: rgba(245, 158, 11, 0.15); color: #F59E0B; }
.tl-badge.ok { background: rgba(34, 197, 94, 0.15); color: #22C55E; }
.stats-bar { padding: 60px 0; border-top: 1px solid rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.05); }
.stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
.stat-item { text-align: center; }
.stat-val { display: block; font-size: 40px; font-weight: 800; background: linear-gradient(135deg, oklch(0.75 0.15 195), oklch(0.70 0.15 235)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.stat-lbl { font-size: 13px; color: rgba(255,255,255,0.5); }
.features-section { padding: 80px 0; }
.features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.feature-card { background: #161616; border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; overflow: hidden; }
.feature-visual { background: linear-gradient(135deg, #0a0a0a, #161616); aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center; }
.feature-icon-center { font-size: 48px; }
.feature-content { padding: 24px; }
.feature-stat { display: block; font-size: 28px; font-weight: 800; }
.feature-stat-lbl { display: block; font-size: 11px; color: rgba(255,255,255,0.4); margin-bottom: 8px; }
.feature-content h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
.feature-content p { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.5; }
.timeline-section { padding: 80px 0; background: #080808; }
.timeline-header { text-align: center; margin-bottom: 48px; }
.timeline-header h2 { font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 700; }
.timeline-flow { display: flex; justify-content: center; align-items: center; }
.timeline-step { text-align: center; padding: 0 32px; }
.step-marker { width: 56px; height: 56px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 800; margin: 0 auto 12px; }
.step-marker.at-risk { background: rgba(239, 68, 68, 0.15); color: #EF4444; }
.step-marker.attention { background: rgba(245, 158, 11, 0.15); color: #F59E0B; }
.step-marker.warning { background: rgba(234, 179, 8, 0.15); color: oklch(0.75 0.15 195); }
.step-marker.success { background: rgba(34, 197, 94, 0.15); color: #22C55E; }
.timeline-step h4 { font-size: 14px; font-weight: 700; margin-bottom: 4px; }
.timeline-step p { font-size: 12px; color: rgba(255,255,255,0.4); }
.timeline-connector { width: 60px; height: 2px; background: linear-gradient(90deg, rgba(255,255,255,0.1), rgba(255,255,255,0.2), rgba(255,255,255,0.1)); }
.cta-section { padding: 80px 0; }
.cta-card { text-align: center; background: linear-gradient(135deg, #161616, #0a0a0a); border: 1px solid rgba(255,255,255,0.08); border-radius: 24px; padding: 60px; }
.cta-card h2 { font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 800; margin-bottom: 32px; }
.cta-btns { display: flex; justify-content: center; gap: 16px; }
@media (max-width: 1024px) { .timeline-flow { flex-wrap: wrap; } .timeline-connector { display: none; } }
@media (max-width: 768px) { .hero-content { grid-template-columns: 1fr; } .hero-visual-area { display: none; } .stats-grid { grid-template-columns: 1fr; } .features-grid { grid-template-columns: 1fr; } }
</style>