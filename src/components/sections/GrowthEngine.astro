            "Reactivación automática",
          ]
        : [
            "Mobile sales app",
            "Ringless voicemail",
            "Snippets and templates",
            "Smart responses",
            "Automatic reactivation",
          ],
  },
  {
    id: "close",
    label: currentLang === "es" ? "Cierra" : "Close",
    title:
      currentLang === "es"
        ? "Cierra ventas con menos fricción"
        : "Close sales with less friction",
    desc:
      currentLang === "es"
        ? "Pasa de interés a pago con un proceso claro y sin bloqueos operativos."
