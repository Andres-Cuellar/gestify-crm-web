}
.mobile-link:hover { background: rgba(255,255,255,0.05); }
.mobile-link-icon {
  width: 28px;
  height: 28px;
  border-radius: 6px;
  background: rgba(255,255,255,0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.5);
}
.mobile-link-top {
  display: block;
  padding: 14px 0;
  font-size: 18px;
  font-weight: 600;
  color: rgba(255,255,255,0.8);
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.mobile-ctas {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 32px;
}

/* Responsive */
@media (min-width: 1024px) {
  .nav-links { display: flex; }
  .mobile-menu-btn { display: none; }
  .nav-cta { display: inline-flex; }
  .nav-cta-outline { display: inline-flex; }
}
</style>

<script>
const toggle = document.getElementById('menu-toggle');
const menu = document.getElementById('mobile-menu');
const close = document.getElementById('menu-close');
const productTrigger = document.getElementById('product-trigger');
const productSection = document.getElementById('mobile-product');

toggle?.addEventListener('click', () => menu?.classList.add('open'));
close?.addEventListener('click', () => menu?.classList.remove('open'));

productTrigger?.addEventListener('click', () => {
  productSection?.classList.toggle('open');
});

document.querySelectorAll('.mobile-section-title').forEach(btn => {
  btn.addEventListener('click', () => {
    const content = btn.nextElementSibling;
    content?.classList.toggle('open');
  });
});
</script>