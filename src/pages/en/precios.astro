---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ui } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';
const currentLang: Lang = 'en';
const t = ui[currentLang];

const plans = [
  {
    name: 'Starter',
    annualPrice: '40.8',
    monthlyPrice: '49',
    annualTotal: '490',
    monthlyTotal: '49',
    desc: 'For agencies getting started.',
    features: ['5 users', '1,000 emails', 'Basic inbox', 'Email support', 'Calendars'],
    cta: 'Get started',
    popular: false,
    emailLimit: '1.000',
    whatsappPrice: '50',
    currency: 'USD',
  },
  {
    name: 'Growth',
    annualPrice: '82.5',
    monthlyPrice: '99',
    annualTotal: '990',
    monthlyTotal: '99',
    desc: 'For growing agencies.',
    features: ['15 users', '10,000 emails', 'AI Agents', 'Automations', 'Integrations', 'Calendars'],
    cta: 'Get started',
    popular: true,
    emailLimit: '10.000',
    whatsappIncluded: true,
    currency: 'USD',
  },
  {
    name: 'Advanced',
    annualPrice: '225',
    monthlyPrice: '270',
    annualTotal: '2.700',
    monthlyTotal: '270',
    desc: 'For agencies that want to dominate.',
    features: ['50 users', '30,000 emails', 'API access', 'Priority support', 'Calendars', 'No white-label'],
    cta: 'Get started',
    popular: false,
    emailLimit: '30.000',
    whatsappIncluded: true,
    noWhitelabel: true,
    currency: 'USD',
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    desc: 'For special needs.',
    features: ['Unlimited users', 'SSO', 'Dedicated SLA', 'Custom onboarding'],
    cta: 'Talk to sales',
    popular: false,
  },
];

const faqs = [
  { q: 'Can I change plans later?', a: 'Yes, you can upgrade or downgrade anytime. Changes apply to your next billing cycle.' },
  { q: 'What does WhatsApp include?', a: 'WhatsApp includes chat channel, Instagram and Facebook Messenger in a single unified inbox.' },
  { q: 'What happens if I exceed users on Starter?', a: 'We\'ll notify you when you reach 80% usage. You can upgrade to Growth with one click.' },
  { q: 'Is there a free trial?', a: 'Yes, 7 days free no credit card required. Try all Growth plan features.' },
  { q: 'Can I migrate from another platform?', a: 'Yes, we offer assisted migration on all plans.' },
];
---

<BaseLayout title="Pricing" lang={currentLang}>
  <section class="page-hero">
    <div class="container">
      <span class="section-tag fade-in" style="width:fit-content;"><span class="section-tag-dot"></span>Pricing</span>
      <h1 class="page-title fade-in" style="transition-delay:100ms;">Simple and transparent</h1>
      <p class="page-sub fade-in" style="transition-delay:200ms;">No surprises. No hidden fees. Just results. Choose the plan that best fits your agency.</p>
    </div>
  </section>

<!-- Billing Toggle -->
  <div class="billing-toggle fade-in">
    <span class="billing-label">Monthly</span>
    <label class="toggle">
      <input type="checkbox" id="billing-toggle" checked>
      <span class="toggle-slider"></span>
    </label>
    <span class="billing-label">Annual</span>
  </div>

  <section class="section section-dark">
    <div class="container">
      <div class="plans-grid">
        {plans.map((p, i) => (
          <div class={`plan-card fade-in ${p.popular ? 'popular' : ''}`} style={`transition-delay:${i * 100}ms;`}>
            {p.popular && <span class="plan-badge">Most popular</span>}
            <div class="plan-name">{p.name}</div>
            <div class="plan-price">
              {p.price !== 'Custom' ? (
                <>
                  <span class="plan-num" data-annual={p.annualPrice} data-monthly={p.monthlyPrice}>{p.annualPrice}</span>
                  <span class="plan-currency">USD</span>
                  <span class="plan-period">/mo</span>
                </>
              ) : <span class="plan-num">{p.price}</span>}
            </div>
            {p.price !== 'Custom' && (
              <div class="plan-total" data-annual={`$${p.annualTotal} billed annually`} data-monthly={`$${p.monthlyTotal} billed monthly`}>
                ${p.annualTotal} billed annually
              </div>
            )}
            {p.price !== 'Custom' && (
              <div class="plan-email-limit">{p.emailLimit} emails</div>
            )}
            {p.whatsappPrice && (
              <div class="plan-whatsapp">WhatsApp +{p.whatsappPrice} COP/mo</div>
            )}
            {p.whatsappIncluded && (
              <div class="plan-whatsapp included">✓ WhatsApp included (IG + FB)</div>
            )}
            <div class="plan-desc">{p.desc}</div>
            <div class="plan-divider"></div>
            <ul class="plan-features">
              {p.features.map(f => <li>{f}</li>)}
            </ul>
            <a href={`/en/thank-you?plan=${p.name.toLowerCase()}&billing=annual`} class={`plan-btn ${p.popular ? 'primary' : ''} plan-btn-annual`} data-monthly-href={`/en/thank-you?plan=${p.name.toLowerCase()}&billing=monthly`} data-annual-href={`/en/thank-you?plan=${p.name.toLowerCase()}&billing=annual`}>{p.cta}</a>
          </div>
        ))}
      </div>

      <div class="trust-row fade-in" style="margin-top: 48px; text-align: center;">
        <span class="trust-text">✓ No credit card · ✓ 7 days free · ✓ Cancel anytime</span>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <h2 class="section-title fade-in" style="text-align:center; margin-bottom: 48px;">Frequently asked questions</h2>
      <div class="faq-grid">
        {faqs.map((f, i) => (
          <div class="faq-item fade-in" style={`transition-delay:${i * 100}ms;`}>
            <h4 class="faq-q">{f.q}</h4>
            <p class="faq-a">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('billing-toggle');
    const prices = document.querySelectorAll('.plan-num[data-annual]');
    const totals = document.querySelectorAll('.plan-total[data-annual]');
    const buttons = document.querySelectorAll('.plan-btn-annual');

    toggle?.addEventListener('change', () => {
      const isAnnual = toggle.checked;
      prices.forEach(p => {
        const el = p;
        el.textContent = isAnnual ? el.dataset.annual : el.dataset.monthly;
      });
      totals.forEach(t => {
        const el = t;
        el.textContent = isAnnual ? el.dataset.annual : el.dataset.monthly;
      });
      buttons.forEach(btn => {
        const el = btn;
        el.href = isAnnual ? el.dataset.annualHref : el.dataset.monthlyHref;
      });
    });
  });
</script>

<style>
.page-hero { padding: 160px 0 80px; text-align: center; }
.page-title { font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 700; line-height: 1.1; margin: 20px auto 24px; max-width: 700px; }
.page-sub { font-size: 18px; color: rgba(255,255,255,0.5); max-width: 600px; margin: 0 auto; line-height: 1.7; }
.billing-toggle { display: flex; align-items: center; justify-content: center; gap: 12px; padding: 0 0 32px; }
.billing-label { font-size: 14px; color: rgba(255,255,255,0.6); }
.toggle { position: relative; width: 48px; height: 26px; }
.toggle input { opacity: 0; width: 0; height: 0; }
.toggle-slider { position: absolute; inset: 0; background: rgba(255,255,255,0.1); border-radius: 9999px; cursor: pointer; transition: background 0.3s; }
.toggle-slider::before { content: ''; position: absolute; width: 20px; height: 20px; left: 3px; bottom: 3px; background: white; border-radius: 50%; transition: transform 0.3s; }
.toggle input:checked + .toggle-slider { background: oklch(0.75 0.15 195); }
.toggle input:checked + .toggle-slider::before { transform: translateX(22px); }
.plans-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
.plan-card { padding: 28px; background: #161616; border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; position: relative; }
.plan-card.popular { border-color: oklch(0.75 0.15 195); }
.plan-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); padding: 6px 16px; background: oklch(0.75 0.15 195); color: #050505; font-size: 11px; font-weight: 700; text-transform: uppercase; border-radius: 9999px; white-space: nowrap; }
.plan-name { font-size: 18px; font-weight: 600; margin-bottom: 8px; }
.plan-price { display: flex; align-items: baseline; gap: 4px; margin-bottom: 4px; }
.plan-num { font-size: 32px; font-weight: 700; }
.plan-currency { font-size: 14px; font-weight: 600; margin-left: 2px; opacity: 0.7; }
.plan-period { font-size: 14px; color: rgba(255,255,255,0.4); }
.plan-email-limit { font-size: 12px; color: oklch(0.75 0.15 195); font-weight: 600; margin-top: 4px; }
.plan-whatsapp { font-size: 11px; color: rgba(255,255,255,0.5); margin-top: 2px; }
.plan-whatsapp.included { color: oklch(0.70 0.15 145); }
.plan-desc { font-size: 13px; color: rgba(255,255,255,0.4); margin-bottom: 20px; }
.plan-divider { height: 1px; background: rgba(255,255,255,0.08); margin-bottom: 20px; }
.plan-features { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
.plan-features li { font-size: 13px; color: rgba(255,255,255,0.6); display: flex; align-items: flex-start; gap: 8px; }
.plan-features li::before { content: '✓'; color: oklch(0.65 0.15 145); font-weight: 600; flex-shrink: 0; }
.plan-btn { width: 100%; padding: 12px; border-radius: 9999px; font-size: 14px; font-weight: 600; text-align: center; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fafafa; cursor: pointer; transition: all 0.2s; }
.plan-btn:hover { background: rgba(255,255,255,0.1); }
.plan-btn.primary { background: oklch(0.75 0.15 195); color: #050505; border: none; }
.plan-btn.primary:hover { opacity: 0.9; }
.trust-text { font-size: 14px; color: rgba(255,255,255,0.4); }
.faq-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; }
.faq-item { }
.faq-q { font-size: 16px; font-weight: 600; margin-bottom: 8px; }
.faq-a { font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.6; }
@media (max-width: 1024px) { .plans-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 640px) { .plans-grid { grid-template-columns: 1fr; } .faq-grid { grid-template-columns: 1fr; } }
</style>