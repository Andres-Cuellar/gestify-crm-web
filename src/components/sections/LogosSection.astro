---
import { ui } from '@/i18n/ui';
import type { Lang } from '@/i18n/ui';

interface Props { currentLang: Lang; }
const { currentLang } = Astro.props;

const brands = [
  { name: 'Toyota', color: '#EB0A1B' },
  { name: 'McDonalds', color: '#FFBD2E' },
  { name: 'British Airways', color: '#075AAA' },
  { name: 'Radisson', color: '#004A97' },
  { name: 'Subway', color: '#00853F' },
  { name: 'Decathlon', color: '#008AC9' },
  { name: 'Hertz', color: '#FF4A00' },
  { name: 'Roche', color: '#E8001D' },
];
---

<section class="logos-section">
  <div class="container">
    <p class="logos-label fade-in">
      {currentLang === 'es' ? 'Más de 10,000 negocios confían en Gestify' : '10k+ brands trust Gestify'}
    </p>
    <div class="logos-grid fade-in" style="transition-delay: 100ms;">
      {brands.map(brand => (
        <div class="logo-item" style={`--logo-color: ${brand.color};`}>
          <div class="logo-placeholder">
            <span>{brand.name}</span>
          </div>
        </div>
      ))}
    </div>
    <div class="logos-cta fade-in" style="transition-delay: 200ms;">
      <a href="#">
        {currentLang === 'es' ? 'Ver casos de éxito →' : 'Explore success stories →'}
      </a>
    </div>
  </div>
</section>

<style>
.logos-section {
  padding: 60px 0;
  text-align: center;
}
.logos-label {
  font-size: 13px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.4);
  margin-bottom: 32px;
}
.logos-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 32px 48px;
  margin-bottom: 32px;
}
.logo-item {
  display: flex;
  align-items: center;
  justify-content: center;
}
.logo-placeholder {
  width: 100px;
  height: 40px;
  background: rgba(255,255,255,0.05);
  border: 1px dashed rgba(255,255,255,0.15);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}
.logo-placeholder:hover {
  border-color: var(--logo-color);
  background: color-mix(in srgb, var(--logo-color) 10%, transparent);
}
.logo-placeholder span {
  font-size: 12px;
  font-weight: 700;
  color: rgba(255,255,255,0.3);
  letter-spacing: -0.02em;
}
.logos-cta a {
  font-size: 14px;
  color: oklch(0.75 0.15 195);
  font-weight: 600;
}
.logos-cta a:hover { text-decoration: underline; }
</style>