---
import { ArrowRight, Play, Check } from 'lucide-astro';
import { ui } from '@/i18n/ui';
import type { Lang } from '@/i18n/ui';

interface Props { currentLang: Lang; }
const { currentLang } = Astro.props;
const t = ui[currentLang];

const trustItems = currentLang === 'es'
  ? ['Sin tarjeta de crédito', '7 días gratis', 'Cancelar cuando quieras']
  : ['No credit card', '7 days free', 'Cancel anytime'];
---

<section class="hero">
  <div class="hero-bg">
    <div class="hero-orb1"></div>
    <div class="hero-orb2"></div>
  </div>

  <div class="container hero-content">
    <div class="hero-grid">

      <!-- Left: Content -->
      <div>
        <span class="fade-in section-tag" style="width: fit-content;">
          <span class="section-tag-dot"></span>
          {currentLang === 'es' ? 'Para negocios que quieren escalar' : 'For agencies that want to scale'}
        </span>

        <h1 class="hero-title fade-in" style="transition-delay: 100ms;">
          <span>{currentLang === 'es' ? 'La plataforma' : 'The platform'}</span>
          <span class="accent">{currentLang === 'es' ? 'todo-en-uno' : 'all-in-one'}</span>
          <span>{currentLang === 'es' ? 'que escala' : 'that scales'}</span>
          <span class="accent">{currentLang === 'es' ? 'tu agencia' : 'your agency'}</span>
        </h1>

        <p class="hero-subtitle fade-in" style="transition-delay: 200ms;">
          {t.hero.subtitle}
        </p>

        <div class="hero-btns fade-in" style="transition-delay: 300ms;">
          <a href="#" class="btn btn-primary">
            {t.hero.cta.startFree}
            <ArrowRight size={16} />
          </a>
          <a href={`/${currentLang}/demo`} class="btn btn-outline">
            <Play size={16} />
            {t.hero.cta.bookDemo}
          </a>
        </div>

        <div class="hero-trust fade-in" style="transition-delay: 400ms;">
          {trustItems.map(item => (
            <div class="trust-item">
              <span class="trust-dot"><Check size={10} /></span>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Dashboard -->
      <div class="dashboard fade-in" style="transition-delay: 250ms;">
        <div class="dash-card">
          <div class="dash-header">
            <div class="dash-dots"><span></span><span></span><span></span></div>
            <div class="dash-url"></div>
          </div>

          <div class="stats-row">
            <div class="stat-card main">
              <div class="stat-value">340%</div>
              <div class="stat-label">{currentLang === 'es' ? 'Aumento en leads' : 'Lead increase'}</div>
              <div class="stat-bar"><div class="stat-bar-fill"></div></div>
            </div>
            <div class="stat-card">
              <div class="stat-value accent">3x</div>
              <div class="stat-label">{currentLang === 'es' ? 'Clientes' : 'Clients'}</div>
            </div>
          </div>

          <div class="chart-box">
            <svg viewBox="0 0 200 80" preserveAspectRatio="none">
              <defs>
                <linearGradient id="g" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="oklch(0.75 0.15 195)" stop-opacity="0.3"/>
                  <stop offset="100%" stop-color="oklch(0.75 0.15 195)" stop-opacity="0"/>
                </linearGradient>
              </defs>
              <path d="M0 60 Q30 50 60 45 T120 25 T160 20 T200 15 L200 80 L0 80 Z" fill="url(#g)"/>
              <path d="M0 60 Q30 50 60 45 T120 25 T160 20 T200 15" fill="none" stroke="oklch(0.75 0.15 195)" stroke-width="2"/>
              <circle cx="160" cy="20" r="4" fill="oklch(0.75 0.15 195)"/>
            </svg>
          </div>

          <div class="activity-title">{currentLang === 'es' ? 'Actividad reciente' : 'Recent activity'}</div>
          <div class="activity-item">
            <div class="activity-dot green"></div>
            <div>
              <div class="activity-name">{currentLang === 'es' ? 'Nuevo lead de WhatsApp' : 'New WhatsApp lead'}</div>
              <div class="activity-time">María García · 2min</div>
            </div>
          </div>
          <div class="activity-item">
            <div class="activity-dot yellow"></div>
            <div>
              <div class="activity-name">{currentLang === 'es' ? 'Venta cerrada - $2,400' : 'Sale closed - $2,400'}</div>
              <div class="activity-time">Carlos R. · 15min</div>
            </div>
          </div>
        </div>

        <!-- Floating badges -->
        <div class="badge-float badge-top">
          <div class="badge-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div>
            <div class="badge-val">+127%</div>
            <div class="badge-lbl">{currentLang === 'es' ? 'conversiones' : 'conversions'}</div>
          </div>
        </div>

        <div class="badge-float badge-bottom">
          <div class="users-row">
            <div class="user-circle"></div>
            <div class="user-circle"></div>
            <div class="user-circle"></div>
          </div>
          <span class="badge-lbl">+500 {currentLang === 'es' ? 'negocios' : 'agencies'}</span>
        </div>
      </div>

    </div>
  </div>
</section>