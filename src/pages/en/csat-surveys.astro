---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ArrowRight } from 'lucide-astro';
import type { Lang } from '../../i18n/ui';
const currentLang: Lang = 'en';

const features = [
  {
    title: 'Automatic Surveys',
    desc: 'CSAT, NPS, CES surveys sent automatically post-interaction. Zero effort, maximum insight.',
    stat: '60%',
    statLabel: 'More responses',
    color: 'oklch(0.75 0.15 195)',
  },
  {
    title: 'NPS Tracking',
    desc: 'Measure promoters, passives, and detractors. Automatic follow-up for detractors with recovery flow.',
    stat: '+25',
    statLabel: 'NPS points',
    color: 'oklch(0.70 0.15 235)',
  },
  {
    title: 'Trend Analysis',
    desc: 'Identify patterns in satisfaction. Alerts when metrics drop for immediate intervention.',
    stat: '90%',
    statLabel: 'Early detection',
    color: 'oklch(0.65 0.15 145)',
  },
];

const capabilities = [
  { title: 'Multi-channel delivery', desc: 'Send via WhatsApp, email, SMS based on customer preference.' },
  { title: 'Custom scoring', desc: 'Configure thresholds and specific metrics for your business.' },
  { title: 'Closed-loop alerts', desc: 'Notifications when a dissatisfied customer needs attention.' },
  { title: 'Benchmarking', desc: 'Compare your NPS against industry.' },
];
---

<BaseLayout title="CSAT and NPS Surveys" lang={currentLang}>
  <!-- Hero -->
  <section class="hero-product">
    <div class="container">
      <div class="announce-badge fade-in">
        <span>📊</span>
        <span>Customer satisfaction analytics</span>
        <a href="#">Learn more →</a>
      </div>
      <h1 class="hero-product-title fade-in" style="transition-delay:100ms;">
        Know what your customers think before losing them
      </h1>
      <p class="hero-product-sub fade-in" style="transition-delay:200ms;">
        Automated surveys that measure satisfaction and activate recovery when something goes wrong. Data that drives growth.
      </p>
      <div class="hero-ctas fade-in" style="transition-delay:300ms;">
        <a href={`/${currentLang}/demo`} class="btn btn-primary">
          Talk to sales <ArrowRight size={16} />
        </a>
        <a href="#" class="btn btn-outline">
          Start free trial
        </a>
      </div>

      <!-- Stats -->
      <div class="hero-stats fade-in" style="transition-delay:400ms;">
        <div class="hero-stat">
          <span class="stat-val">60%</span>
          <span class="stat-lbl">More responses</span>
        </div>
        <div class="hero-stat">
          <span class="stat-val">+25</span>
          <span class="stat-lbl">NPS points</span>
        </div>
        <div class="hero-stat">
          <span class="stat-val">90%</span>
          <span class="stat-lbl">Early detection</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Logos -->
  <section class="logos-mini">
    <div class="container">
      <p class="logos-label">10k+ agencies trust Gestify</p>
      <div class="logos-row">
        <span>Toyota</span>
        <span>McDonalds</span>
        <span>British Airways</span>
        <span>Radisson</span>
        <span>Subway</span>
        <span>Decathlon</span>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section-capture">
    <div class="container">
      <div class="section-header-center fade-in">
        <h2>Measure, analyze, improve</h2>
        <p>Continuous feedback that closes the loop between satisfaction and operations. Every survey is an opportunity to improve.</p>
      </div>

      <div class="capture-cards">
        {features.map((f, i) => (
          <div class="capture-card fade-in" style={`transition-delay:${i * 100}ms;`}>
            <div class="capture-card-header">
              <div class="capture-stat">
                <span class="capture-stat-val" style={`color: ${f.color};`}>{f.stat}</span>
                <span class="capture-stat-lbl">{f.statLabel}</span>
              </div>
            </div>
            <h3 class="capture-card-title">{f.title}</h3>
            <p class="capture-card-desc">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Survey Types -->
  <section class="section-flow">
    <div class="container">
      <div class="section-header-center fade-in">
        <h2>Survey types</h2>
      </div>
      <div class="survey-types">
        <div class="survey-card fade-in">
          <div class="survey-score great">+50</div>
          <h4>CSAT</h4>
          <p>Customer Satisfaction Score</p>
        </div>
        <div class="survey-card fade-in" style="transition-delay:100ms;">
          <div class="survey-score">42</div>
          <h4>NPS</h4>
          <p>Net Promoter Score</p>
        </div>
        <div class="survey-card fade-in" style="transition-delay:200ms;">
          <div class="survey-score">+20</div>
          <h4>CES</h4>
          <p>Customer Effort Score</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="section-capabilities">
    <div class="container">
      <div class="section-header-center fade-in">
        <h2>Actionable insights</h2>
      </div>
      <div class="cap-grid">
        {capabilities.map((cap, i) => (
          <div class="cap-card fade-in" style={`transition-delay:${i * 80}ms;`}>
            <h4 class="cap-title">{cap.title}</h4>
            <p class="cap-desc">{cap.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-cta">
    <div class="container">
      <h2 class="cta-title fade-in">Feedback that improves your business 📊</h2>
      <div class="cta-btns fade-in" style="transition-delay:100ms;">
        <a href={`/${currentLang}/demo`} class="btn btn-primary">Talk to sales</a>
        <a href="#" class="btn btn-outline">Start free trial</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.hero-product { padding: 140px 0 60px; text-align: center; }
.announce-badge { display: inline-flex; align-items: center; gap: 10px; padding: 8px 16px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 9999px; font-size: 13px; color: rgba(255,255,255,0.7); margin-bottom: 32px; }
.announce-badge a { color: oklch(0.75 0.15 195); font-weight: 600; }
.hero-product-title { font-size: clamp(2.2rem, 5vw, 4rem); font-weight: 800; line-height: 1.1; max-width: 800px; margin: 0 auto 20px; }
.hero-product-sub { font-size: 18px; color: rgba(255,255,255,0.5); max-width: 600px; margin: 0 auto 36px; line-height: 1.6; }
.hero-ctas { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; margin-bottom: 48px; }
.hero-stats { display: flex; justify-content: center; gap: 60px; padding: 32px; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 20px; max-width: 700px; margin: 0 auto; }
.hero-stat { display: flex; flex-direction: column; gap: 4px; text-align: center; }
.stat-val { font-size: 32px; font-weight: 800; background: linear-gradient(135deg, oklch(0.75 0.15 195), oklch(0.70 0.15 235)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.stat-lbl { font-size: 12px; color: rgba(255,255,255,0.5); }
.logos-mini { padding: 40px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
.logos-label { text-align: center; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.35); margin-bottom: 24px; }
.logos-row { display: flex; justify-content: center; flex-wrap: wrap; gap: 40px; }
.logos-row span { font-size: 16px; font-weight: 700; color: rgba(255,255,255,0.25); }
.section-capture { padding: 80px 0; }
.section-header-center { text-align: center; max-width: 650px; margin: 0 auto 48px; }
.section-header-center h2 { font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 700; margin-bottom: 12px; }
.section-header-center p { font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.6; }
.capture-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.capture-card { padding: 28px; background: #161616; border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; text-align: left; }
.capture-card-header { margin-bottom: 20px; }
.capture-stat { display: inline-flex; flex-direction: column; gap: 2px; }
.capture-stat-val { font-size: 36px; font-weight: 800; }
.capture-stat-lbl { font-size: 12px; color: rgba(255,255,255,0.5); }
.capture-card-title { font-size: 18px; font-weight: 700; margin-bottom: 10px; }
.capture-card-desc { font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.6; }
.section-flow { padding: 80px 0; background: #080808; }
.survey-types { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.survey-card { padding: 32px; background: #161616; border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; text-align: center; }
.survey-score { font-size: 48px; font-weight: 800; color: oklch(0.75 0.15 195); margin-bottom: 16px; }
.survey-score.great { color: #22C55E; }
.survey-card h4 { font-size: 16px; font-weight: 700; margin-bottom: 4px; }
.survey-card p { font-size: 12px; color: rgba(255,255,255,0.5); }
.section-capabilities { padding: 80px 0; }
.cap-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
.cap-card { padding: 24px; background: #161616; border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; }
.cap-title { font-size: 14px; font-weight: 700; margin-bottom: 8px; }
.cap-desc { font-size: 12px; color: rgba(255,255,255,0.5); line-height: 1.6; }
.section-cta { padding: 100px 0; text-align: center; }
.cta-title { font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 800; margin-bottom: 32px; }
.cta-btns { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; }
@media (max-width: 1024px) { .cap-grid { grid-template-columns: repeat(2, 1fr); } .survey-types { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 768px) { .capture-cards { grid-template-columns: 1fr; } .hero-stats { flex-direction: column; gap: 24px; } }
</style>