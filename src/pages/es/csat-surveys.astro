---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ArrowRight } from 'lucide-astro';
import type { Lang } from '../../i18n/ui';
const currentLang: Lang = 'es';

const features = [
  {
    title: 'Automatic Surveys',
    desc: 'CSAT, NPS, CES surveys enviados automáticamente post-interacción.',
    stat: '60%',
    statLabel: 'Más responses',
    color: 'oklch(0.75 0.15 195)',
    icon: '📋',
  },
  {
    title: 'NPS Tracking',
    desc: 'Mide promoters, passives y detractors con follow-up automático.',
    stat: '+25',
    statLabel: 'Puntos NPS',
    color: 'oklch(0.70 0.15 235)',
    icon: '📈',
  },
  {
    title: 'Trend Analysis',
    desc: 'Identifica patrones en satisfacción con alertas tempranas.',
    stat: '90%',
    statLabel: 'Detección temprana',
    color: 'oklch(0.65 0.15 145)',
    icon: '🔍',
  },
];
---

<BaseLayout title="CSAT y NPS Surveys" lang={currentLang}>
  <!-- Hero with Image Area -->
  <section class="hero-visual">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <div class="announce-badge fade-in">
            <span>📊</span>
            <span>Customer satisfaction analytics</span>
          </div>
          <h1 class="hero-title fade-in" style="transition-delay:100ms;">
            Sabe qué piensan tus clientes antes de perderlos
          </h1>
          <p class="hero-sub fade-in" style="transition-delay:200ms;">
            Surveys automatizados que miden satisfacción y activan recuperación cuando algo sale mal.
          </p>
          <div class="hero-ctas fade-in" style="transition-delay:300ms;">
            <a href={`/${currentLang}/demo`} class="btn btn-primary">
              Hablar con ventas <ArrowRight size={16} />
            </a>
            <a href="#" class="btn btn-outline">
              Empezar prueba gratis
            </a>
          </div>
        </div>
        <div class="hero-visual-area fade-in" style="transition-delay:200ms;">
          <div class="survey-dashboard-visual">
            <div class="dash-header">
              <span>📊 CSAT Dashboard</span>
            </div>
            <div class="score-cards">
              <div class="score-card">
                <span class="score-val great">+50</span>
                <span class="score-type">CSAT</span>
              </div>
              <div class="score-card">
                <span class="score-val">42</span>
                <span class="score-type">NPS</span>
              </div>
              <div class="score-card">
                <span class="score-val">+20</span>
                <span class="score-type">CES</span>
              </div>
            </div>
            <div class="trend-chart">
              <span>📈</span>
              <span>Satisfaction Trend</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="stats-bar">
    <div class="container">
      <div class="stats-grid fade-in">
        <div class="stat-item">
          <span class="stat-val">60%</span>
          <span class="stat-lbl">Más responses</span>
        </div>
        <div class="stat-item">
          <span class="stat-val">+25</span>
          <span class="stat-lbl">Puntos NPS</span>
        </div>
        <div class="stat-item">
          <span class="stat-val">90%</span>
          <span class="stat-lbl">Detección temprana</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Features with Visual -->
  <section class="features-section">
    <div class="container">
      <div class="features-grid">
        {features.map((f, i) => (
          <div class="feature-card fade-in" style={`transition-delay:${i * 100}ms;`}>
            <div class="feature-visual">
              <div class="feature-icon-center">{f.icon}</div>
            </div>
            <div class="feature-content">
              <span class="feature-stat" style={`color: ${f.color};`}>{f.stat}</span>
              <span class="feature-stat-lbl">{f.statLabel}</span>
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Survey Types Visual -->
  <section class="survey-types-section">
    <div class="container">
      <div class="section-header-center fade-in">
        <h2>Tipos de surveys</h2>
      </div>
      <div class="survey-types-grid">
        <div class="survey-type-card fade-in">
          <div class="survey-image-placeholder">
            <span>+50</span>
            <span>CSAT Score</span>
          </div>
          <h3>CSAT</h3>
          <p>Customer Satisfaction Score</p>
        </div>
        <div class="survey-type-card fade-in" style="transition-delay:100ms;">
          <div class="survey-image-placeholder">
            <span>42</span>
            <span>NPS Score</span>
          </div>
          <h3>NPS</h3>
          <p>Net Promoter Score</p>
        </div>
        <div class="survey-type-card fade-in" style="transition-delay:200ms;">
          <div class="survey-image-placeholder">
            <span>+20</span>
            <span>CES Score</span>
          </div>
          <h3>CES</h3>
          <p>Customer Effort Score</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-card fade-in">
        <h2>Feedback que mejora tu negocio 📊</h2>
        <div class="cta-btns">
          <a href={`/${currentLang}/demo`} class="btn btn-primary">Hablar con ventas</a>
          <a href="#" class="btn btn-outline">Empezar prueba gratis</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.hero-visual { padding: 140px 0 60px; }
.hero-content { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.announce-badge { display: inline-flex; align-items: center; gap: 10px; padding: 8px 16px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 9999px; font-size: 13px; color: rgba(255,255,255,0.7); margin-bottom: 24px; }
.hero-title { font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 800; line-height: 1.1; margin-bottom: 20px; }
.hero-sub { font-size: 18px; color: rgba(255,255,255,0.5); line-height: 1.6; margin-bottom: 32px; }
.hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; }
.survey-dashboard-visual { background: linear-gradient(145deg, #1a1a1a, #0a0a0a); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 20px; }
.dash-header { font-size: 12px; color: rgba(255,255,255,0.5); margin-bottom: 16px; }
.score-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 16px; }
.score-card { background: #161616; border-radius: 12px; padding: 16px; text-align: center; }
.score-val { display: block; font-size: 28px; font-weight: 800; color: oklch(0.75 0.15 195); }
.score-val.great { color: #22C55E; }
.score-type { font-size: 11px; color: rgba(255,255,255,0.4); }
.trend-chart { background: #161616; border-radius: 12px; aspect-ratio: 16/6; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; }
.trend-chart span:first-child { font-size: 28px; }
.trend-chart span:last-child { font-size: 11px; color: rgba(255,255,255,0.3); }
.stats-bar { padding: 60px 0; border-top: 1px solid rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.05); }
.stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
.stat-item { text-align: center; }
.stat-val { display: block; font-size: 40px; font-weight: 800; background: linear-gradient(135deg, oklch(0.75 0.15 195), oklch(0.70 0.15 235)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.stat-lbl { font-size: 13px; color: rgba(255,255,255,0.5); }
.features-section { padding: 80px 0; }
.features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.feature-card { background: #161616; border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; overflow: hidden; }
.feature-visual { background: linear-gradient(135deg, #0a0a0a, #161616); aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center; }
.feature-icon-center { font-size: 48px; }
.feature-content { padding: 24px; }
.feature-stat { display: block; font-size: 28px; font-weight: 800; }
.feature-stat-lbl { display: block; font-size: 11px; color: rgba(255,255,255,0.4); margin-bottom: 8px; }
.feature-content h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
.feature-content p { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.5; }
.survey-types-section { padding: 80px 0; background: #080808; }
.section-header-center { text-align: center; max-width: 650px; margin: 0 auto 48px; }
.section-header-center h2 { font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 700; margin-bottom: 12px; }
.survey-types-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.survey-type-card { background: #161616; border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; overflow: hidden; }
.survey-image-placeholder { background: linear-gradient(135deg, #0a0a0a, #161616); aspect-ratio: 16/10; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; }
.survey-image-placeholder span:first-child { font-size: 36px; font-weight: 800; color: oklch(0.75 0.15 195); }
.survey-image-placeholder span:last-child { font-size: 12px; color: rgba(255,255,255,0.4); }
.survey-type-card h3 { padding: 16px 16px 8px; font-size: 16px; font-weight: 700; }
.survey-type-card p { padding: 0 16px 16px; font-size: 13px; color: rgba(255,255,255,0.5); }
.cta-section { padding: 80px 0; }
.cta-card { text-align: center; background: linear-gradient(135deg, #161616, #0a0a0a); border: 1px solid rgba(255,255,255,0.08); border-radius: 24px; padding: 60px; }
.cta-card h2 { font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 800; margin-bottom: 32px; }
.cta-btns { display: flex; justify-content: center; gap: 16px; }
@media (max-width: 768px) { .hero-content { grid-template-columns: 1fr; } .hero-visual-area { display: none; } .stats-grid { grid-template-columns: 1fr; } .features-grid { grid-template-columns: 1fr; } .survey-types-grid { grid-template-columns: 1fr; } }
</style>