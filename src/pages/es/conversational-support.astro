---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ArrowRight } from 'lucide-astro';
import type { Lang } from '../../i18n/ui';
const currentLang: Lang = 'es';

const features = [
  {
    title: 'Ticket Management',
    desc: 'Transforma chats en tickets trackeables. SLA monitoring, prioridades automáticas.',
    stat: '60%',
    statLabel: 'Tiempo de resolución',
    color: 'oklch(0.65 0.15 145)',
    icon: '🎫',
  },
  {
    title: 'CSAT Management',
    desc: 'Mide satisfacción post-interacción con surveys automatizados.',
    stat: '4.6',
    statLabel: 'CSAT promedio',
    color: 'oklch(0.75 0.15 195)',
    icon: '⭐',
  },
  {
    title: 'Knowledge Base',
    desc: 'Crea una base de conocimiento que tu IA usa para responder.',
    stat: '80%',
    statLabel: 'Self-service rate',
    color: 'oklch(0.70 0.15 235)',
    icon: '📚',
  },
];
---

<BaseLayout title="Soporte conversacional que fideliza" lang={currentLang}>
  <!-- Hero with Image Area -->
  <section class="hero-visual">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <div class="announce-badge fade-in">
            <span>💬</span>
            <span>Soporte omnicanal con IA</span>
          </div>
          <h1 class="hero-title fade-in" style="transition-delay:100ms;">
            Soporte que convierte clientes en promotores
          </h1>
          <p class="hero-sub fade-in" style="transition-delay:200ms;">
            Un inbox unificado para todos tus canales. IA que asiste a tus agentes y clientes que quedan satisfechos.
          </p>
          <div class="hero-ctas fade-in" style="transition-delay:300ms;">
            <a href={`/${currentLang}/demo`} class="btn btn-primary">
              Hablar con ventas <ArrowRight size={16} />
            </a>
            <a href="#" class="btn btn-outline">
              Empezar prueba gratis
            </a>
          </div>
        </div>
        <div class="hero-visual-area fade-in" style="transition-delay:200ms;">
          <div class="inbox-preview-visual">
            <div class="inbox-header-bar">
              <span>📥 Unified Inbox</span>
            </div>
            <div class="inbox-channels-bar">
              <div class="channel-tab active">
                <span class="wa-dot"></span>
                WhatsApp
              </div>
              <div class="channel-tab">
                <span class="fb-dot"></span>
                Facebook
              </div>
              <div class="channel-tab">
                <span class="email-dot"></span>
                Email
              </div>
            </div>
            <div class="inbox-threads">
              <div class="thread-item">
                <div class="thread-avatar">MG</div>
                <div class="thread-info">
                  <span class="thread-name">María García</span>
                  <span class="thread-preview">Hola, tengo un problema con mi pedido...</span>
                </div>
                <div class="thread-status open">Open</div>
              </div>
              <div class="thread-item resolved">
                <div class="thread-avatar">CR</div>
                <div class="thread-info">
                  <span class="thread-name">Carlos Ruiz</span>
                  <span class="thread-preview">Gracias por la ayuda!</span>
                </div>
                <div class="thread-status">Resolved</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="stats-bar">
    <div class="container">
      <div class="stats-grid fade-in">
        <div class="stat-item">
          <span class="stat-val">60%</span>
          <span class="stat-lbl">Tiempo de resolución</span>
        </div>
        <div class="stat-item">
          <span class="stat-val">4.6</span>
          <span class="stat-lbl">CSAT promedio</span>
        </div>
        <div class="stat-item">
          <span class="stat-val">80%</span>
          <span class="stat-lbl">Self-service rate</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Features with Visual -->
  <section class="features-section">
    <div class="container">
      <div class="features-grid">
        {features.map((f, i) => (
          <div class="feature-card fade-in" style={`transition-delay:${i * 100}ms;`}>
            <div class="feature-visual">
              <div class="feature-icon-center">{f.icon}</div>
            </div>
            <div class="feature-content">
              <span class="feature-stat" style={`color: ${f.color};`}>{f.stat}</span>
              <span class="feature-stat-lbl">{f.statLabel}</span>
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Inbox Visual Demo -->
  <section class="inbox-demo-section">
    <div class="container">
      <div class="demo-grid">
        <div class="demo-content fade-in">
          <h2>Un inbox, todos los canales</h2>
          <p>WhatsApp, Facebook, Instagram, email, live chat... todos en una sola vista. Sin cambiar entre apps.</p>
          <ul class="demo-list">
            <li>📥 Mensajes de todos canales en un solo lugar</li>
            <li>🤖 AI que asiste y acelera respuestas</li>
            <li>📊 Métricas de performance en tiempo real</li>
            <li>🔄 Transferencia fluida entre agentes</li>
          </ul>
        </div>
        <div class="demo-visual fade-in" style="transition-delay:100ms;">
          <div class="inbox-ui-demo">
            <div class="ui-header">
              <span>💬</span>
              <span>Conversaciones</span>
            </div>
            <div class="ui-conversation">
              <div class="conv-msg">Hola, necesito ayuda con mi orden</div>
              <div class="conv-msg user">Claro, ¿me puedes dar tu número de orden?</div>
              <div class="conv-msg">Es la #4521</div>
              <div class="conv-msg bot">Perfecto, encontré tu orden. Tu envío llega mañana antes del mediodía 🚚</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-card fade-in">
        <h2>Convierte soporte en tu ventaja competitiva 💬</h2>
        <div class="cta-btns">
          <a href={`/${currentLang}/demo`} class="btn btn-primary">Hablar con ventas</a>
          <a href="#" class="btn btn-outline">Empezar prueba gratis</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.hero-visual { padding: 140px 0 60px; }
.hero-content { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.announce-badge { display: inline-flex; align-items: center; gap: 10px; padding: 8px 16px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 9999px; font-size: 13px; color: rgba(255,255,255,0.7); margin-bottom: 24px; }
.hero-title { font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 800; line-height: 1.1; margin-bottom: 20px; }
.hero-sub { font-size: 18px; color: rgba(255,255,255,0.5); line-height: 1.6; margin-bottom: 32px; }
.hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; }
.inbox-preview-visual { background: linear-gradient(145deg, #1a1a1a, #0a0a0a); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 20px; }
.inbox-header-bar { font-size: 12px; color: rgba(255,255,255,0.5); margin-bottom: 16px; }
.inbox-channels-bar { display: flex; gap: 8px; margin-bottom: 16px; }
.channel-tab { display: flex; align-items: center; gap: 6px; padding: 8px 12px; background: #161616; border-radius: 8px; font-size: 11px; color: rgba(255,255,255,0.5); }
.channel-tab.active { background: oklch(0.75 0.15 195); color: #000; }
.wa-dot { width: 8px; height: 8px; border-radius: 50%; background: #25D366; }
.fb-dot { width: 8px; height: 8px; border-radius: 50%; background: #1877F2; }
.email-dot { width: 8px; height: 8px; border-radius: 50%; background: oklch(0.75 0.15 195); }
.inbox-threads { display: flex; flex-direction: column; gap: 8px; }
.thread-item { display: flex; align-items: center; gap: 12px; padding: 12px; background: #161616; border-radius: 10px; }
.thread-item.resolved { opacity: 0.5; }
.thread-avatar { width: 36px; height: 36px; border-radius: 50%; background: oklch(0.75 0.15 195); color: #000; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; }
.thread-info { flex: 1; }
.thread-name { display: block; font-size: 13px; font-weight: 600; }
.thread-preview { font-size: 11px; color: rgba(255,255,255,0.4); }
.thread-status { font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 6px; background: rgba(37, 211, 102, 0.15); color: #25D366; }
.thread-status.open { background: rgba(37, 211, 102, 0.15); color: #25D366; }
.stats-bar { padding: 60px 0; border-top: 1px solid rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.05); }
.stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
.stat-item { text-align: center; }
.stat-val { display: block; font-size: 40px; font-weight: 800; background: linear-gradient(135deg, oklch(0.75 0.15 195), oklch(0.70 0.15 235)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.stat-lbl { font-size: 13px; color: rgba(255,255,255,0.5); }
.features-section { padding: 80px 0; }
.features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.feature-card { background: #161616; border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; overflow: hidden; }
.feature-visual { background: linear-gradient(135deg, #0a0a0a, #161616); aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center; }
.feature-icon-center { font-size: 48px; }
.feature-content { padding: 24px; }
.feature-stat { display: block; font-size: 28px; font-weight: 800; }
.feature-stat-lbl { display: block; font-size: 11px; color: rgba(255,255,255,0.4); margin-bottom: 8px; }
.feature-content h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
.feature-content p { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.5; }
.inbox-demo-section { padding: 80px 0; background: #080808; }
.demo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.demo-content h2 { font-size: clamp(1.6rem, 2.5vw, 2.2rem); font-weight: 700; margin-bottom: 16px; }
.demo-content p { font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.6; margin-bottom: 24px; }
.demo-list { list-style: none; }
.demo-list li { padding: 10px 0; font-size: 15px; color: rgba(255,255,255,0.8); }
.inbox-ui-demo { background: #161616; border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; overflow: hidden; }
.ui-header { display: flex; align-items: center; gap: 8px; padding: 12px 16px; background: #222; font-size: 12px; color: rgba(255,255,255,0.5); }
.ui-conversation { padding: 16px; display: flex; flex-direction: column; gap: 8px; }
.conv-msg { padding: 10px 14px; border-radius: 12px; font-size: 13px; background: #222; color: rgba(255,255,255,0.8); max-width: 85%; }
.conv-msg.user { align-self: flex-end; background: oklch(0.70 0.15 235); color: #fff; }
.conv-msg.bot { background: rgba(34, 197, 94, 0.15); color: #22C55E; }
.cta-section { padding: 80px 0; }
.cta-card { text-align: center; background: linear-gradient(135deg, #161616, #0a0a0a); border: 1px solid rgba(255,255,255,0.08); border-radius: 24px; padding: 60px; }
.cta-card h2 { font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 800; margin-bottom: 32px; }
.cta-btns { display: flex; justify-content: center; gap: 16px; }
@media (max-width: 1024px) { .demo-grid { grid-template-columns: 1fr; } }
@media (max-width: 768px) { .hero-content { grid-template-columns: 1fr; } .hero-visual-area { display: none; } .stats-grid { grid-template-columns: 1fr; } .features-grid { grid-template-columns: 1fr; } }
</style>