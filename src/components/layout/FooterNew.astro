---
import { Mail } from 'lucide-astro';
import { ui } from '@/i18n/ui';
import type { Lang } from '@/i18n/ui';

interface Props { currentLang: Lang; }
const { currentLang } = Astro.props;
const t = ui[currentLang];
---

<footer class="footer-new">
  <div class="container">
    <!-- Top CTA -->
    <div class="footer-cta">
      <h2 class="footer-cta-title">
        {currentLang === 'es' ? '3x tus resultados con Gestify 🚀' : '3x your business results with Gestify 🚀'}
      </h2>
      <div class="footer-cta-btns">
        <a href={`/${currentLang}/demo`} class="btn btn-primary">
          {currentLang === 'es' ? 'Hablar con ventas' : 'Talk to Sales'}
        </a>
        <a href="#" class="btn btn-outline">
          {currentLang === 'es' ? 'Empezar prueba gratis' : 'Start Free Trial'}
        </a>
      </div>
    </div>

    <!-- Links Grid -->
    <div class="footer-links-grid">
      <div class="footer-col-wide">
        <div class="footer-logo">
          <img src="/logo.webp" alt="Gestify" style="height: 28px; filter: brightness(0) invert(1);" />
        </div>
        <p class="footer-tagline">
          {currentLang === 'es'
            ? 'La plataforma todo-en-uno para agencies que quieren escalar.'
            : 'The all-in-one platform for agencies that want to scale.'}
        </p>
        <div class="footer-badges">
          <span class="footer-badge">GDPR Compliant</span>
          <span class="footer-badge">ISO 27001</span>
        </div>
      </div>

      <div class="footer-col">
        <h4 class="footer-col-title">Product</h4>
        <ul>
          <li><a href={`/${currentLang}/producto`}>Features</a></li>
          <li><a href={`/${currentLang}/soluciones`}>Industries</a></li>
          <li><a href="#">Integrations</a></li>
          <li><a href="#">API</a></li>
          <li><a href="#">Pricing</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-col-title">Resources</h4>
        <ul>
          <li><a href={`/${currentLang}/recursos`}>Blog</a></li>
          <li><a href="#">Help Center</a></li>
          <li><a href="#">Webinars</a></li>
          <li><a href="#">Community</a></li>
          <li><a href="#">Documentation</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-col-title">Company</h4>
        <ul>
          <li><a href="#">About Us</a></li>
          <li><a href="#">Careers</a></li>
          <li><a href="#">Press</a></li>
          <li><a href={`/${currentLang}/contacto`}>Contact</a></li>
          <li><a href="#">Partners</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-col-title">Compare</h4>
        <ul>
          <li><a href="#">vs HubSpot</a></li>
          <li><a href="#">vs Zendesk</a></li>
          <li><a href="#">vs Intercom</a></li>
          <li><a href="#">vs Manychat</a></li>
          <li><a href="#">vs Wati</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-col-title">Legal</h4>
        <ul>
          <li><a href="#">Privacy Policy</a></li>
          <li><a href="#">Cookie Policy</a></li>
          <li><a href="#">Terms of Service</a></li>
          <li><a href="#">Security</a></li>
          <li><a href="#">Data Protection</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="footer-copyright">© 2025 Gestify. {currentLang === 'es' ? 'Todos los derechos reservados.' : 'All rights reserved.'}</p>
      <div class="footer-partners">
        <span class="partner-tag">Meta Business Partner</span>
        <span class="partner-tag">TikTok Marketing Partner</span>
      </div>
      <a href="mailto:hola@gestify.us" class="footer-email">
        <Mail size={14} />
        hola@gestify.us
      </a>
    </div>
  </div>
</footer>

<style>
.footer-new {
  padding: 80px 0 40px;
  background: #080808;
  border-top: 1px solid rgba(255,255,255,0.05);
}
.footer-cta {
  text-align: center;
  padding: 60px 0;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  margin-bottom: 60px;
}
.footer-cta-title {
  font-size: clamp(1.8rem, 3vw, 2.5rem);
  font-weight: 800;
  margin-bottom: 32px;
}
.footer-cta-btns {
  display: flex;
  justify-content: center;
  gap: 16px;
}
.footer-links-grid {
  display: grid;
  grid-template-columns: 2fr repeat(5, 1fr);
  gap: 40px;
  margin-bottom: 60px;
}
.footer-logo { margin-bottom: 12px; }
.footer-tagline {
  font-size: 13px;
  color: rgba(255,255,255,0.4);
  line-height: 1.6;
  margin-bottom: 16px;
}
.footer-badges {
  display: flex;
  gap: 12px;
}
.footer-badge {
  font-size: 11px;
  font-weight: 600;
  padding: 4px 10px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 6px;
  color: rgba(255,255,255,0.5);
}
.footer-col-title {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: rgba(255,255,255,0.5);
  margin-bottom: 16px;
}
.footer-col ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.footer-col ul li a {
  font-size: 13px;
  color: rgba(255,255,255,0.6);
}
.footer-col ul li a:hover { color: #fff; }
.footer-bottom {
  padding-top: 30px;
  border-top: 1px solid rgba(255,255,255,0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 20px;
}
.footer-copyright {
  font-size: 13px;
  color: rgba(255,255,255,0.3);
}
.footer-partners {
  display: flex;
  gap: 16px;
}
.partner-tag {
  font-size: 11px;
  font-weight: 600;
  color: rgba(255,255,255,0.4);
}
.footer-email {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: rgba(255,255,255,0.4);
}
.footer-email:hover { color: #fff; }
@media (max-width: 1024px) {
  .footer-links-grid { grid-template-columns: repeat(3, 1fr); }
  .footer-col-wide { grid-column: 1 / -1; }
}
@media (max-width: 640px) {
  .footer-links-grid { grid-template-columns: repeat(2, 1fr); }
  .footer-bottom { flex-direction: column; text-align: center; }
}
</style>