---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ArrowRight } from 'lucide-astro';
import { ui } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';
const currentLang: Lang = 'en';

const captureFeatures = [
  {
    title: 'Meta Click to Chat Ads',
    desc: 'Capture leads where they\'re most active with Click to Messenger Ads and Instagram Ads. Turn ad clicks into real-time conversations.',
    stat: '10x',
    statLabel: 'More leads',
    color: 'oklch(0.70 0.15 235)',
  },
  {
    title: 'TikTok Messaging Ads',
    desc: 'Engage instantly with high-intent audiences on the world\'s fastest-growing social app with over 1.5 billion active users.',
    stat: '50%',
    statLabel: 'More revenue-driving chats',
    color: 'oklch(0.75 0.15 195)',
  },
  {
    title: 'Handle High Volumes',
    desc: 'Turn ads into revenue with AI and automation. Ensure every inquiry is addressed by automatically qualifying and routing leads.',
    stat: '84%',
    statLabel: 'Increase in conversions',
    color: 'oklch(0.65 0.15 280)',
  },
];

const captureItems = [
  { title: 'Facebook', desc: 'Chat links, comment replies, Live' },
  { title: 'Instagram', desc: 'Story links, auto replies, DM buttons' },
  { title: 'TikTok', desc: 'DMs, bio links, TikTok Live' },
];

const capabilities = [
  {
    title: 'Omnichannel team inbox',
    desc: 'Unify contacts and conversations from voice calls, email, WhatsApp, TikTok, Facebook Messenger, Instagram and more.',
    icon: 'M22 17a2 2 0 0 1-2 2H6.828a2 2 0 0 0-1.414.586l-2.202 2.202A.71.71 0 0 1 2 21.286V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2z',
  },
  {
    title: 'AI Agents',
    desc: 'Deploy ready-made or custom AI Agents to answer FAQs, qualify leads, update customer data and lifecycle stages, route enquiries to the right team, book appointments.',
    icon: 'M12 8V4H8M8 12H2M22 12h-4M16 12a4 4 0 1 1-8 0 4 4 0 0 1 8 0zM6 18h.01M10 18h.01',
  },
  {
    title: 'Automate and integrate',
    desc: 'Connect to HubSpot, Salesforce, Google Sheets, Zapier, Make, n8n and more to automate workflows.',
    icon: 'M7 11v4a2 2 0 0 0 2 2h4M13 11V9a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2',
  },
  {
    title: 'Customer lifecycle management',
    desc: 'Prioritize high-intent leads, design customer journeys for each lifecycle stage or identify common drop-off points.',
    icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
  },
];
---

<BaseLayout title="Capture leads from ads" lang={currentLang}>
  <!-- Hero -->
  <section class="hero-product">
    <div class="container">
      <div class="announce-badge fade-in">
        <span>✨</span>
        <span>Gestify AI Agents — Now with advanced reasoning</span>
        <a href="#">Learn more →</a>
      </div>
      <h1 class="hero-product-title fade-in" style="transition-delay:100ms;">
        10x your lead generation with click to chat ads
      </h1>
      <p class="hero-product-sub fade-in" style="transition-delay:200ms;">
        Turn social engagement into a pipeline of prospects with click to chat ads on Facebook, Instagram and TikTok
      </p>
      <div class="hero-ctas fade-in" style="transition-delay:300ms;">
        <a href={`/${currentLang}/demo`} class="btn btn-primary">
          Talk to Sales <ArrowRight size={16} />
        </a>
        <a href="#" class="btn btn-outline">
          Start Free Trial
        </a>
      </div>

      <!-- Stats -->
      <div class="hero-stats fade-in" style="transition-delay:400ms;">
        <div class="hero-stat">
          <span class="stat-val">10x</span>
          <span class="stat-lbl">More leads</span>
        </div>
        <div class="hero-stat">
          <span class="stat-val">50%</span>
          <span class="stat-lbl">More revenue-driving chats</span>
        </div>
        <div class="hero-stat">
          <span class="stat-val">84%</span>
          <span class="stat-lbl">Increase in conversions</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Logos -->
  <section class="logos-mini">
    <div class="container">
      <p class="logos-label">10k+ brands trust Gestify</p>
      <div class="logos-row">
        <span>Toyota</span>
        <span>McDonalds</span>
        <span>British Airways</span>
        <span>Radisson</span>
        <span>Subway</span>
        <span>Decathlon</span>
      </div>
    </div>
  </section>

  <!-- Capture from channels -->
  <section class="section-capture">
    <div class="container">
      <div class="section-header-center fade-in">
        <h2>Turn ads into instant action</h2>
        <p>Get leads into chats while interest is high, automate responses to keep them engaged and save their details for retargeting.</p>
      </div>

      <div class="capture-cards">
        {captureFeatures.map((f, i) => (
          <div class="capture-card fade-in" style={`transition-delay:${i * 100}ms;`}>
            <div class="capture-card-header">
              <div class="capture-stat">
                <span class="capture-stat-val" style={`color: ${f.color};`}>{f.stat}</span>
                <span class="capture-stat-lbl">{f.statLabel}</span>
              </div>
            </div>
            <h3 class="capture-card-title">{f.title}</h3>
            <p class="capture-card-desc">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Channel specific -->
  <section class="section-channels">
    <div class="container">
      <div class="channels-grid">
        {captureItems.map((item, i) => (
          <a href="#" class="channel-card fade-in" style={`transition-delay:${i * 100}ms;`}>
            <h3 class="channel-title">{item.title}</h3>
            <p class="channel-desc">{item.desc}</p>
            <span class="channel-link">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="section-capabilities">
    <div class="container">
      <div class="section-header-center fade-in">
        <h2>How Gestify turns customer conversations into revenue</h2>
      </div>
      <div class="cap-grid">
        {capabilities.map((cap, i) => (
          <div class="cap-card fade-in" style={`transition-delay:${i * 80}ms;`}>
            <div class="cap-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:22px;height:22px;color:oklch(0.75 0.15 195);">
                <path d={cap.icon}></path>
              </svg>
            </div>
            <h4 class="cap-title">{cap.title}</h4>
            <p class="cap-desc">{cap.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-cta">
    <div class="container">
      <h2 class="cta-title fade-in">3x your business results with Gestify 🚀</h2>
      <div class="cta-btns fade-in" style="transition-delay:100ms;">
        <a href={`/${currentLang}/demo`} class="btn btn-primary">Talk to Sales</a>
        <a href="#" class="btn btn-outline">Start Free Trial</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.hero-product {
  padding: 140px 0 60px;
  text-align: center;
}
.announce-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 8px 16px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 9999px;
  font-size: 13px;
  color: rgba(255,255,255,0.7);
  margin-bottom: 32px;
}
.announce-badge a {
  color: oklch(0.75 0.15 195);
  font-weight: 600;
}
.hero-product-title {
  font-size: clamp(2.2rem, 5vw, 4rem);
  font-weight: 800;
  line-height: 1.1;
  max-width: 800px;
  margin: 0 auto 20px;
}
.hero-product-sub {
  font-size: 18px;
  color: rgba(255,255,255,0.5);
  max-width: 600px;
  margin: 0 auto 36px;
  line-height: 1.6;
}
.hero-ctas {
  display: flex;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 48px;
}
.hero-stats {
  display: flex;
  justify-content: center;
  gap: 60px;
  padding: 32px;
  background: rgba(255,255,255,0.02);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 20px;
  max-width: 700px;
  margin: 0 auto;
}
.hero-stat {
  display: flex;
  flex-direction: column;
  gap: 4px;
  text-align: center;
}
.stat-val {
  font-size: 32px;
  font-weight: 800;
  background: linear-gradient(135deg, oklch(0.75 0.15 195), oklch(0.70 0.15 235));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.stat-lbl {
  font-size: 12px;
  color: rgba(255,255,255,0.5);
}
.logos-mini {
  padding: 40px 0;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.logos-label {
  text-align: center;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.35);
  margin-bottom: 24px;
}
.logos-row {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 40px;
}
.logos-row span {
  font-size: 16px;
  font-weight: 700;
  color: rgba(255,255,255,0.25);
}
.section-capture {
  padding: 80px 0;
}
.section-header-center {
  text-align: center;
  max-width: 650px;
  margin: 0 auto 48px;
}
.section-header-center h2 {
  font-size: clamp(1.8rem, 3vw, 2.5rem);
  font-weight: 700;
  margin-bottom: 12px;
}
.section-header-center p {
  font-size: 16px;
  color: rgba(255,255,255,0.5);
  line-height: 1.6;
}
.capture-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.capture-card {
  padding: 28px;
  background: #161616;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 20px;
  text-align: left;
}
.capture-card-header {
  margin-bottom: 20px;
}
.capture-stat {
  display: inline-flex;
  flex-direction: column;
  gap: 2px;
}
.capture-stat-val {
  font-size: 36px;
  font-weight: 800;
}
.capture-stat-lbl {
  font-size: 12px;
  color: rgba(255,255,255,0.5);
}
.capture-card-title {
  font-size: 18px;
  font-weight: 700;
  margin-bottom: 10px;
}
.capture-card-desc {
  font-size: 14px;
  color: rgba(255,255,255,0.5);
  line-height: 1.6;
}
.section-channels {
  padding: 0 0 80px;
}
.channels-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
.channel-card {
  display: flex;
  flex-direction: column;
  padding: 24px;
  background: #161616;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 16px;
  text-decoration: none;
  transition: border-color 0.2s, transform 0.2s;
}
.channel-card:hover {
  border-color: oklch(0.75 0.15 195);
  transform: translateY(-4px);
}
.channel-title {
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 8px;
}
.channel-desc {
  font-size: 13px;
  color: rgba(255,255,255,0.5);
  flex-grow: 1;
  margin-bottom: 16px;
}
.channel-link {
  font-size: 12px;
  font-weight: 600;
  color: oklch(0.75 0.15 195);
}
.section-capabilities {
  padding: 80px 0;
  background: #080808;
}
.cap-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}
.cap-card {
  padding: 24px;
  background: #161616;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 16px;
}
.cap-icon {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  background: rgba(255,255,255,0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}
.cap-title {
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 8px;
}
.cap-desc {
  font-size: 12px;
  color: rgba(255,255,255,0.5);
  line-height: 1.6;
}
.section-cta {
  padding: 100px 0;
  text-align: center;
}
.cta-title {
  font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  font-weight: 800;
  margin-bottom: 32px;
}
.cta-btns {
  display: flex;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
}
@media (max-width: 1024px) {
  .cap-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
  .capture-cards { grid-template-columns: 1fr; }
  .channels-grid { grid-template-columns: 1fr; }
  .hero-stats { flex-direction: column; gap: 24px; }
}
</style>