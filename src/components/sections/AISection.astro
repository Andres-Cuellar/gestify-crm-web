---
import { Play, ArrowRight } from 'lucide-astro';
import { ui } from '@/i18n/ui';
import type { Lang } from '@/i18n/ui';

interface Props { currentLang: Lang; }
const { currentLang } = Astro.props;

const features = [
  {
    title: currentLang === 'es' ? 'Vende más eficiente' : 'Convert customers efficiently',
    desc: currentLang === 'es'
      ? 'Agentes IA multilingües manejan consultas de ads, responden FAQs y enrutan solo compradores serios a tu equipo para conversiones más rápidas.'
      : 'Multilingual AI Agents handle ad enquiries, answer FAQs and route only serious buyers to your team for faster conversions and higher marketing ROI.',
    color: 'oklch(0.70 0.15 235)',
  },
  {
    title: currentLang === 'es' ? 'Acorta ciclos de venta' : 'Shorten sales cycles',
    desc: currentLang === 'es'
      ? 'Transforma intención en compra eliminando fricción. Agentes IA recomiendan productos, manejan reservas y comparten detalles de pago.'
      : 'Turn intent into purchases by removing friction. AI Agents recommend products, manage bookings and share payment details for seamless customer journeys.',
    color: 'oklch(0.75 0.15 195)',
  },
  {
    title: currentLang === 'es' ? 'Lanza rápido y seguro' : 'Launch quickly and securely',
    desc: currentLang === 'es'
      ? 'Maneja 10x más clientes de forma autónoma con razonamiento avanzado, alta precisión y guardrails incorporados. Empieza con templates o personaliza.'
      : 'Handle 10x more customers autonomously with advanced reasoning, high accuracy and built-in guardrails. Start quickly with AI Agent templates or customize.',
    color: 'oklch(0.65 0.15 145)',
  },
];
---

<section class="ai-section">
  <div class="container">
    <div class="ai-hero-content">
      <div class="ai-text fade-in">
        <span class="section-tag">
          <span class="section-tag-dot"></span>
          AI Agents ✨
        </span>
        <h2 class="ai-title">
          {currentLang === 'es'
            ? 'IA construida sobre una base confiable'
            : 'AI built on a trusted foundation'}
        </h2>
        <p class="ai-sub">
          {currentLang === 'es'
            ? 'Escala sin agregar personal. Acelera el crecimiento en cada canal con Agentes IA que responden, enrutan y ejecutan tareas con precisión y confiabilidad.'
            : 'Scale without adding headcount. Accelerate growth on every channel with AI Agents that respond, route and perform tasks accurately and reliably.'}
        </p>
        <div class="ai-ctas">
          <a href="#" class="btn btn-primary">
            {currentLang === 'es' ? 'Probar Agente IA gratis' : 'Try AI Agent for free'}
            <ArrowRight size={16} />
          </a>
          <button class="btn-video">
            <span class="video-icon"><Play size={14} /></span>
            Play Video
          </button>
        </div>
      </div>

      <div class="ai-visual fade-in" style="transition-delay: 200ms;">
        <div class="ai-video-placeholder">
          <div class="video-play-btn">
            <span>▶</span>
          </div>
          <div class="video-label">
            {currentLang === 'es' ? 'Ver demo interactiva' : 'Watch interactive demo'}
          </div>
        </div>
      </div>
    </div>

    <div class="ai-features-grid">
      {features.map((f, i) => (
        <div class="ai-feat-card fade-in" style={`transition-delay: ${(i + 3) * 100}ms;`}>
          <h4 class="ai-feat-title" style={`color: ${f.color};`}>{f.title}</h4>
          <p class="ai-feat-desc">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.ai-section {
  padding: 100px 0;
  background: #050505;
}
.ai-hero-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
  margin-bottom: 60px;
}
.ai-text .section-tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 14px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 9999px;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  color: oklch(0.75 0.15 195);
  margin-bottom: 24px;
}
.section-tag-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: oklch(0.75 0.15 195);
}
.ai-title {
  font-size: clamp(2rem, 3.5vw, 2.8rem);
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 16px;
}
.ai-sub {
  font-size: 16px;
  color: rgba(255,255,255,0.5);
  line-height: 1.7;
  margin-bottom: 32px;
}
.ai-ctas {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}
.btn-video {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 16px 24px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 9999px;
  font-size: 15px;
  font-weight: 600;
  color: #fafafa;
  cursor: pointer;
}
.video-icon {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: oklch(0.75 0.15 195);
  display: flex;
  align-items: center;
  justify-content: center;
}
.video-icon svg { color: #050505; }
.ai-visual {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}
.ai-video-placeholder {
  grid-column: span 2;
  background: linear-gradient(145deg, #1a1a1a, #0a0a0a);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  min-height: 280px;
}
.video-play-btn {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: oklch(0.75 0.15 195);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  cursor: pointer;
  transition: transform 0.2s ease;
}
.video-play-btn:hover {
  transform: scale(1.1);
}
.video-play-btn span {
  color: #050505;
  margin-left: 4px;
}
.video-label {
  font-size: 14px;
  color: rgba(255,255,255,0.6);
  font-weight: 500;
}
.ai-card {
  background: #161616;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 20px;
  padding: 24px;
}
.ai-card-header {
  margin-bottom: 20px;
}
.ai-badge {
  display: inline-block;
  padding: 8px 14px;
  background: oklch(0.75 0.15 195 / 0.15);
  border: 1px solid oklch(0.75 0.15 195 / 0.3);
  border-radius: 9999px;
  font-size: 12px;
  font-weight: 600;
  color: oklch(0.75 0.15 195);
}
.ai-conversation {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 20px;
}
.ai-msg {
  padding: 12px 16px;
  border-radius: 14px;
  font-size: 13px;
  line-height: 1.5;
}
.ai-msg-user {
  background: oklch(0.70 0.15 235 / 0.15);
  border: 1px solid oklch(0.70 0.15 235 / 0.2);
  align-self: flex-end;
  max-width: 85%;
}
.ai-msg-bot {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.08);
  align-self: flex-start;
  max-width: 85%;
}
.ai-stats-row {
  display: flex;
  gap: 16px;
  padding-top: 16px;
  border-top: 1px solid rgba(255,255,255,0.08);
}
.ai-stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.ai-stat-val {
  font-size: 20px;
  font-weight: 800;
  color: oklch(0.75 0.15 195);
}
.ai-stat-lbl {
  font-size: 11px;
  color: rgba(255,255,255,0.4);
}
.ai-features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.ai-feat-card {
  padding: 28px;
  background: #161616;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 16px;
}
.ai-feat-title {
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 10px;
}
.ai-feat-desc {
  font-size: 13px;
  color: rgba(255,255,255,0.5);
  line-height: 1.6;
}
@media (max-width: 900px) {
  .ai-hero-content { grid-template-columns: 1fr; }
  .ai-features-grid { grid-template-columns: 1fr; }
}
</style>