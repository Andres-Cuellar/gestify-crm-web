---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ArrowRight } from 'lucide-astro';
import type { Lang } from '../../i18n/ui';
const currentLang: Lang = 'es';

const features = [
  {
    title: 'Chat Widgets',
    desc: 'Añade chat en vivo a tu web con AI que responde instantly y captura leads.',
    stat: '85%',
    statLabel: 'Más captura',
    color: 'oklch(0.70 0.15 235)',
    icon: '💬',
  },
  {
    title: 'Lead Forms',
    desc: 'Forms inteligentes que se adaptan al usuario y maximizan conversiones.',
    stat: '3x',
    statLabel: 'Más leads',
    color: 'oklch(0.75 0.15 195)',
    icon: '📝',
  },
  {
    title: 'Proactive Triggers',
    desc: 'Mensajes automáticos basados en comportamiento del usuario en tu web.',
    stat: '40%',
    statLabel: 'Más engagement',
    color: 'oklch(0.65 0.15 280)',
    icon: '⚡',
  },
];
---

<BaseLayout title="Capturar leads de tu web" lang={currentLang}>
  <!-- Hero with Image Area -->
  <section class="hero-visual">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <div class="announce-badge fade-in">
            <span>🌐</span>
            <span>Website Capture Tools</span>
          </div>
          <h1 class="hero-title fade-in" style="transition-delay:100ms;">
            Convierte visitantes anónimos en leads cualificados
          </h1>
          <p class="hero-sub fade-in" style="transition-delay:200ms;">
            Chat widgets, forms inteligentes y triggers proactivos que capturan leads mientras están interesados
          </p>
          <div class="hero-ctas fade-in" style="transition-delay:300ms;">
            <a href={`/${currentLang}/demo`} class="btn btn-primary">
              Hablar con ventas <ArrowRight size={16} />
            </a>
            <a href="#" class="btn btn-outline">
              Empezar prueba gratis
            </a>
          </div>
        </div>
        <div class="hero-visual-area fade-in" style="transition-delay:200ms;">
          <div class="website-preview-visual">
            <div class="browser-chrome">
              <div class="chrome-dots">
                <span></span><span></span><span></span>
              </div>
              <div class="chrome-url">tudominio.com</div>
            </div>
            <div class="website-content">
              <div class="web-content-inner">
                <div class="web-headline">Tu web profesional</div>
                <div class="web-subline">Convierte visitantes en leads</div>
                <div class="web-chat-widget">
                  <div class="widget-header">
                    <span>💬</span>
                    <span>Chat</span>
                  </div>
                  <div class="widget-body">
                    <div class="widget-msg bot">¡Hola! ¿En qué puedo ayudarte?</div>
                    <div class="widget-msg user">Quiero info sobre precios</div>
                    <div class="widget-msg bot">Claro, aquí tienes... <span style="color: oklch(0.75 0.15 195);">Ver planes →</span></div>
                  </div>
                </div>
                <div class="conversion-toast">
                  <span>📧</span>
                  <span>Lead capturado: maria@email.com</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="stats-bar">
    <div class="container">
      <div class="stats-grid fade-in">
        <div class="stat-item">
          <span class="stat-val">85%</span>
          <span class="stat-lbl">Más captura con chat</span>
        </div>
        <div class="stat-item">
          <span class="stat-val">3x</span>
          <span class="stat-lbl">Más leads con forms</span>
        </div>
        <div class="stat-item">
          <span class="stat-val">40%</span>
          <span class="stat-lbl">Más engagement</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Features with Visual -->
  <section class="features-section">
    <div class="container">
      <div class="features-grid">
        {features.map((f, i) => (
          <div class="feature-card fade-in" style={`transition-delay:${i * 100}ms;`}>
            <div class="feature-visual">
              <div class="feature-icon-center">{f.icon}</div>
            </div>
            <div class="feature-content">
              <span class="feature-stat" style={`color: ${f.color};`}>{f.stat}</span>
              <span class="feature-stat-lbl">{f.statLabel}</span>
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Widget Preview Visual -->
  <section class="widget-preview-section">
    <div class="container">
      <div class="preview-grid">
        <div class="preview-content fade-in">
          <h2>Widget de chat que convierte</h2>
          <p>Nuesto widget de chat está diseñado para maximizar captures. IA que responde instantáneamente y guía a los visitantes hacia la conversión.</p>
          <ul class="preview-list">
            <li>🎯 AI que entiende intención</li>
            <li>📋 Recopila datos automáticamente</li>
            <li>🔗 Guarda directamente en CRM</li>
            <li>📊 Analytics en tiempo real</li>
          </ul>
        </div>
        <div class="preview-widget-visual fade-in" style="transition-delay:100ms;">
          <div class="widget-demo">
            <div class="demo-header">Live Chat Widget</div>
            <div class="demo-body">
              <div class="demo-msg bot">👋 ¡Hola! ¿En qué puedo ayudarte hoy?</div>
              <div class="demo-msg user">Necesito información</div>
              <div class="demo-msg bot">Claro! Te ayudo con eso. ¿Podrías darme tu email?</div>
              <div class="demo-msg user">maria@company.com</div>
              <div class="demo-msg bot confirmed">✅ Perfecto Maria, te-enviamos la info!</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-card fade-in">
        <h2>Empieza a capturar leads de tu web 🌐</h2>
        <div class="cta-btns">
          <a href={`/${currentLang}/demo`} class="btn btn-primary">Hablar con ventas</a>
          <a href="#" class="btn btn-outline">Empezar prueba gratis</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.hero-visual { padding: 140px 0 60px; }
.hero-content { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.announce-badge { display: inline-flex; align-items: center; gap: 10px; padding: 8px 16px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 9999px; font-size: 13px; color: rgba(255,255,255,0.7); margin-bottom: 24px; }
.hero-title { font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 800; line-height: 1.1; margin-bottom: 20px; }
.hero-sub { font-size: 18px; color: rgba(255,255,255,0.5); line-height: 1.6; margin-bottom: 32px; }
.hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; }
.website-preview-visual { background: linear-gradient(145deg, #1a1a1a, #0a0a0a); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; overflow: hidden; height: 380px; display: flex; flex-direction: column; }
.browser-chrome { background: #222; padding: 12px 16px; display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
.chrome-dots { display: flex; gap: 6px; }
.chrome-dots span { width: 10px; height: 10px; border-radius: 50%; background: #444; }
.chrome-url { flex: 1; text-align: center; font-size: 11px; color: rgba(255,255,255,0.4); background: #161616; padding: 4px 12px; border-radius: 4px; }
.website-content { flex: 1; padding: 20px; position: relative; background: #0a0a0a; }
.web-content-inner { position: relative; width: 100%; height: 100%; }
.web-headline { font-size: 24px; font-weight: 700; color: rgba(255,255,255,0.9); margin-bottom: 4px; }
.web-subline { font-size: 13px; color: rgba(255,255,255,0.4); margin-bottom: 20px; }
.web-chat-widget { position: absolute; bottom: 20px; right: 20px; width: 260px; background: #161616; border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.4); }
.widget-header { display: flex; align-items: center; gap: 8px; padding: 12px 16px; background: oklch(0.75 0.15 195); color: #000; font-size: 13px; font-weight: 600; }
.widget-body { padding: 12px; display: flex; flex-direction: column; gap: 8px; }
.widget-msg { padding: 8px 12px; border-radius: 10px; font-size: 12px; max-width: 90%; }
.widget-msg.bot { background: #222; color: rgba(255,255,255,0.8); align-self: flex-start; }
.widget-msg.user { background: oklch(0.70 0.15 235); color: #fff; align-self: flex-end; }
.conversion-toast { position: absolute; top: 20px; left: 20px; display: flex; align-items: center; gap: 8px; padding: 10px 16px; background: rgba(34, 197, 94, 0.15); border: 1px solid rgba(34, 197, 94, 0.3); border-radius: 10px; font-size: 12px; color: #22C55E; }
.stats-bar { padding: 60px 0; border-top: 1px solid rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.05); }
.stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
.stat-item { text-align: center; }
.stat-val { display: block; font-size: 40px; font-weight: 800; background: linear-gradient(135deg, oklch(0.75 0.15 195), oklch(0.70 0.15 235)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.stat-lbl { font-size: 13px; color: rgba(255,255,255,0.5); }
.features-section { padding: 80px 0; }
.features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.feature-card { background: #161616; border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; overflow: hidden; }
.feature-visual { background: linear-gradient(135deg, #0a0a0a, #161616); aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center; }
.feature-icon-center { font-size: 48px; }
.feature-content { padding: 24px; }
.feature-stat { display: block; font-size: 28px; font-weight: 800; }
.feature-stat-lbl { display: block; font-size: 11px; color: rgba(255,255,255,0.4); margin-bottom: 8px; }
.feature-content h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
.feature-content p { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.5; }
.widget-preview-section { padding: 80px 0; background: #080808; }
.preview-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.preview-content h2 { font-size: clamp(1.6rem, 2.5vw, 2.2rem); font-weight: 700; margin-bottom: 16px; }
.preview-content p { font-size: 16px; color: rgba(255,255,255,0.5); line-height: 1.6; margin-bottom: 24px; }
.preview-list { list-style: none; }
.preview-list li { padding: 10px 0; font-size: 15px; color: rgba(255,255,255,0.8); }
.preview-widget-visual { }
.widget-demo { background: #161616; border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; overflow: hidden; }
.demo-header { padding: 12px 16px; background: #222; font-size: 12px; color: rgba(255,255,255,0.5); }
.demo-body { padding: 16px; display: flex; flex-direction: column; gap: 8px; }
.demo-msg { padding: 10px 14px; border-radius: 12px; font-size: 13px; max-width: 90%; }
.demo-msg.bot { background: #222; color: rgba(255,255,255,0.8); align-self: flex-start; }
.demo-msg.user { background: oklch(0.70 0.15 235); color: #fff; align-self: flex-end; }
.demo-msg.confirmed { background: rgba(34, 197, 94, 0.15); color: #22C55E; }
.cta-section { padding: 80px 0; }
.cta-card { text-align: center; background: linear-gradient(135deg, #161616, #0a0a0a); border: 1px solid rgba(255,255,255,0.08); border-radius: 24px; padding: 60px; }
.cta-card h2 { font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 800; margin-bottom: 32px; }
.cta-btns { display: flex; justify-content: center; gap: 16px; }
@media (max-width: 1024px) { .preview-grid { grid-template-columns: 1fr; } }
@media (max-width: 768px) { .hero-content { grid-template-columns: 1fr; } .hero-visual-area { display: none; } .stats-grid { grid-template-columns: 1fr; } .features-grid { grid-template-columns: 1fr; } }
</style>